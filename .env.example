# Copy this file to .env and adjust if needed.
# For local docker-compose, the default below already matches
# docker-compose.yml's db service.

DATABASE_URL=postgres://totalvibe:totalvibe@localhost:5433/totalvibe

# Must be at least 32 characters, random, and secret — used to encrypt
# the staff shift-session cookie. Generate one with:
#   openssl rand -base64 32
SESSION_SECRET=replace-this-with-a-random-32-plus-character-secret

# Used to build the exact URL written onto NFC fobs. Change this to your
# real domain before provisioning fobs for production use.
APP_BASE_URL=http://localhost:3002

# Timezone the business actually operates in. Promo punch days (see
# CLAUDE.md "Promo punch days") are keyed off "today's date," and without
# this the database defaults to UTC — which can be a different calendar
# date than the shop's local time, especially late at night. Aiken, SC is
# America/New_York.
TZ=America/New_York

# Leave this false until the app is served over real HTTPS (e.g. via
# Caddy — see vps-crash-course.md). Only flip to true once that's in
# place; a Secure cookie over plain HTTP is silently dropped by the
# browser and login will appear to fail with no clear error. See
# src/lib/session.ts.
COOKIE_SECURE=false
